{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hello-world-svelte-app-bindings",
  "compatibility_date": "2025-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "worker/index.ts",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "db",
      "database_id": "local",
      "migrations_dir": "drizzle"
    }
  ],
  "kv_namespaces": [
    { "binding": "SESSIONS", "id": "local" },
    { "binding": "FLAGS", "id": "local-flags" }
  ],
  "r2_buckets": [
    { "binding": "MEDIA", "bucket_name": "media" }
  ]
}
